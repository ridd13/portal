# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (für Bestätigungslinks, OG-Tags etc.)
# Lokal: http://localhost:3000
# Produktion: https://www.das-portal.online
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (E-Mail-Versand für Double Opt-In)
# Hol dir deinen API Key unter https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# Supabase Service Role Key (für API-Endpoints die RLS umgehen)
# ⚠️ NIEMALS als NEXT_PUBLIC_ prefixen!
# Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Event-Import API Key (n8n sendet diesen im Authorization Header)
# Frei wählen — langer zufälliger String
EVENT_IMPORT_API_KEY=portal-import-your-random-string

# Sentry (optional, für Error-Tracking)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Plausible Analytics
# Script wird immer geladen — Plausible ignoriert localhost-Traffic automatisch.
# Im Plausible-Dashboard muss das-portal.online als Site eingetragen sein.
# data-domain ist hardcoded auf "das-portal.online" in app/layout.tsx.
